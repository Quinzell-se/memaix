# Memaix — hemligheter. Kopiera till .env och fyll i. Checka ALDRIG in .env.

# --- Cloudflare tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=             # från: cloudflared tunnel token <tunnel-id>

# --- Hydra OAuth-server ---
HYDRA_DB_PASSWORD=                   # generera: openssl rand -hex 32
HYDRA_SYSTEM_SECRET=                 # generera: openssl rand -hex 32
HYDRA_PUBLIC_URL=https://mcp.example.com
HYDRA_LOGIN_URL=https://mcp.example.com/login
HYDRA_CONSENT_URL=https://mcp.example.com/consent

# --- Memaix gateway ---
TOKEN_MASTER_KEY=                    # generera: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Login-app ---
MEMAIX_ALLOWED_USERS=jimmy
MEMAIX_LOGIN_PASSWORD_HASH=          # generera med scripts/gen-password-hash.py

# --- Backend-credentials (per projekt; referras från config/acl.yaml via *_ref) ---
# Exempel: PM_QRONKBOTS_IMAP_PASSWORD=
# NEXTCLOUD_APP_PASSWORD=

# --- Nextcloud (valfritt) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=            # generera: openssl rand -hex 16
NEXTCLOUD_PUBLIC_HOST=
