# Memaix — hemligheter. Kopiera till .env och fyll i. Checka ALDRIG in .env.

# --- OAuth signing ---
MEMAIX_OAUTH_SIGNING_KEY=            # generera: openssl rand -hex 32

# --- Backend-credentials (per projekt; referras från config/acl.yaml via *_ref) ---
# Exempel: projektet "acme" har mejl och nextcloud
PM_ACME_IMAP_PASSWORD=
NEXTCLOUD_ACME_APP_PASSWORD=

# --- Cloudflare tunnel (om provider: cloudflared) ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Säkerhetsspärr ---
ALLOW_SEND=false                     # true tillåter att AI skickar mejl (default: bara utkast)
